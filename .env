APP_NAME="BIMA AI"
APP_ENV=local
APP_KEY=base64:mP0yTPf0ZC1ezhK4+iY9YetGgZqJ+++NrvVBNhdRG6o=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agentic_ai_voice
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting: Laravel Reverb (free, self-hosted WebSocket) ──
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=bima-app-001
REVERB_APP_KEY=bima-key-local
REVERB_APP_SECRET=bima-secret-local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Queue: database (no Redis needed) ──
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=300

FILESYSTEM_DISK=local
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

